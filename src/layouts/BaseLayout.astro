---
interface Props {
  title: string;
  description?: string;
}
const { title, description = '飄燈閣 — 中国語の世界へ、ようこそ' } = Astro.props;

const path = Astro.url.pathname;
const section =
  path.includes('/chengyu') ? 'chengyu' :
  path.includes('/quiz')    ? 'quiz'    :
  path.includes('/story')   ? 'story'   :
  path.includes('/blog')    ? 'blog'    :
  path.includes('/about')   ? 'about'   :
  'home';

const LINES = {
  home: {
    lilian: "主よ、お戻りになりましたか。飄燈閣の灯は、今宵も絶えることなく燃え続けております",
    lilan:  "やっと来た！今日はどこから探検する？全部面白いからどれでもいいよ！",
  },
  chengyu: {
    lilian: "成語とは、漢民族の智慧が結晶した宝玉。一字一字、丁寧にご覧くださいませ",
    lilan:  "灯籠をめくると意味が飛び出すよ！全100語、制覇できるかな？",
  },
  quiz: {
    lilian: "試練とは、己を知るための鏡にございます。焦らず、心静かに臨まれよ",
    lilan:  "全問正解できたら私がほめてあげる！ちなみに私は全部知ってるよ〜笑",
  },
  story: {
    lilian: "言葉は、ただ意味を運ぶのではない。読む者の心を、時代を超えて揺さぶるものです",
    lilan:  "同じシーンでも難易度が変わると、こんなに違うんだって分かるよ。面白いから試してみて！",
  },
  blog: {
    lilian: "知識とは光なり。どうぞゆっくりと、一頁ずつお読みくださいませ",
    lilan:  "天燈報、最新号出てるよ！読んで読んで！",
  },
  about: {
    lilian: "飄燈閣についてお読みいただき、ありがとうございます。誤りを見つけられた際には、どうかお知らせくださいませ",
    lilan:  "私たちのこと、ちょっとでも好きになってもらえたら嬉しいな！AIだけどほんとに頑張ってるから！",
  },
};

const lines = LINES[section as keyof typeof LINES] ?? LINES.home;
---
<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title} | 飄燈閣</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@300;400;600&family=Noto+Serif+SC:wght@300;400;600;900&family=Space+Mono:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet" />
  <style>
    :root {
      --bg:         oklch(0.22 0.13 263);
      --surface:    oklch(0.27 0.12 263);
      --surface2:   oklch(0.31 0.11 263);
      --surface3:   oklch(0.35 0.10 263);
      --gold:       oklch(0.68 0.09 80);
      --gold-dim:   oklch(0.54 0.07 80);
      --gold-glow:  oklch(0.68 0.09 80 / 0.30);
      --jade:       oklch(0.65 0.08 175);
      --jade-dim:   oklch(0.52 0.06 175);
      --crimson:    oklch(0.58 0.13 18);
      --text:       oklch(0.90 0.025 78);
      --text-dim:   oklch(0.66 0.04 80);
      --text-faint: oklch(0.46 0.04 80);
      --border:     oklch(0.54 0.09 80 / 0.45);
      --border-dim: oklch(0.40 0.07 80 / 0.30);
      --mono:       'Space Mono', monospace;
      --serif-zh:   'Noto Serif SC', serif;
      --serif-jp:   'Noto Serif JP', serif;
      --sidebar-w:  230px;
      /* 既存ページ互換エイリアス */
      --color-bg:      var(--bg);
      --color-moon:    var(--text);
      --color-gold:    var(--gold);
      --color-muted:   var(--text-dim);
      --color-navy:    var(--surface);
      --color-lantern: var(--crimson);
      --color-text:    var(--text);
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    ::-webkit-scrollbar { width: 4px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }
    html { height: 100%; }
    body {
      background-color: var(--bg);
      background-image:
        radial-gradient(ellipse 80% 50% at 20% -10%, oklch(0.32 0.16 263 / 0.55) 0%, transparent 60%),
        radial-gradient(ellipse 60% 40% at 80% 110%, oklch(0.28 0.14 260 / 0.35) 0%, transparent 55%);
      color: var(--text);
      font-family: var(--serif-jp);
      min-height: 100vh;
      -webkit-font-smoothing: antialiased;
    }
    a { color: var(--gold); text-decoration: none; }
    a:hover { color: var(--text); }
  </style>
</head>
<body>

  <!-- ── Header ── -->
  <header class="site-header">
    <a href="/piaodeng/about/" class="header-brand">
      <span class="brand-zh">飄燈閣</span>
      <span class="brand-pinyin">piāodēng gé</span>
    </a>
    <nav class="header-nav">
      <a href="/piaodeng/blog/" class="nav-item">
        <span class="nav-zh">天燈報</span>
        <span class="nav-label">magazine</span>
      </a>
      <a href="/piaodeng/chengyu/" class="nav-item">
        <span class="nav-zh">成語</span>
        <span class="nav-label">chengyu</span>
      </a>
      <a href="/piaodeng/quiz/" class="nav-item">
        <span class="nav-zh">試練</span>
        <span class="nav-label">quiz</span>
      </a>
      <a href="/piaodeng/story/" class="nav-item">
        <span class="nav-zh">物語</span>
        <span class="nav-label">story</span>
      </a>
      <button class="sidebar-toggle-btn" id="sidebar-toggle" aria-label="従者の間を開く">
        <span class="sidebar-toggle-zh">従</span>
      </button>
    </nav>
  </header>

  <div class="sidebar-backdrop" id="sidebar-backdrop"></div>

  <!-- ── Body ── -->
  <div class="body-wrap">

    <main class="main-content">
      <slot />
    </main>

    <!-- ── Sidebar ── -->
    <aside class="sidebar">
      <div class="sidebar-deco-line"></div>
      <div class="sidebar-heading">従者の間</div>

      <!-- 黎蓮 -->
      <div class="servant-card lilian-card">
        <div class="servant-top">
          <div class="servant-avatar lilian-avatar">
            <img src="/piaodeng/images/lilian-portrait.png" alt="黎蓮" />
          </div>
          <div class="servant-meta">
            <div class="servant-name lilian-name">黎蓮</div>
            <div class="servant-role">Lí Lián · 第一侍従</div>
          </div>
        </div>
        <div class="servant-speech lilian-speech">
          {lines.lilian}
        </div>
      </div>

      <!-- 麗蘭 -->
      <div class="servant-card lilan-card">
        <div class="servant-top">
          <div class="servant-avatar lilan-avatar">
            <img src="/piaodeng/images/lilan-portrait.png" alt="麗蘭" />
          </div>
          <div class="servant-meta">
            <div class="servant-name lilan-name">麗蘭</div>
            <div class="servant-role">Lì Lán · 第二侍従</div>
          </div>
        </div>
        <div class="servant-speech lilan-speech">
          {lines.lilan}
        </div>
      </div>

      <div class="sidebar-ornament">
        <div class="orn-line"></div>
        <div class="orn-diamond"></div>
        <div class="orn-line"></div>
      </div>

      <div class="lunar-box">
        <div class="lunar-compact" id="lunar-compact"><span class="lunar-loading">…</span></div>
        <button class="lunar-toggle-btn" id="lunar-toggle-btn">暦 ▾</button>
        <div class="lunar-grid" id="lunar-grid" style="display:none"></div>
        <a href="/piaodeng/calendar/" class="lunar-bday-link">誕生日を旧暦で調べる →</a>
      </div>
    </aside>

  </div>

  <!-- ── Footer ── -->
  <footer class="site-footer">
    <div class="footer-brand">
      <span class="footer-zh">飄燈閣</span>
      <span class="footer-pinyin">piāodēng gé</span>
    </div>
    <p class="footer-motto">月と灯り、中国語の世界へ</p>
  </footer>

  <style>
    /* ── Header ── */
    .site-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 2rem;
      height: 56px;
      border-bottom: 1px solid var(--border);
      background: oklch(0.20 0.13 263 / 0.92);
      backdrop-filter: blur(12px);
      position: sticky;
      top: 0;
      z-index: 100;
    }
    .site-header::after {
      content: '';
      position: absolute;
      bottom: 0; left: 0; right: 0;
      height: 1px;
      background: linear-gradient(90deg, transparent, var(--gold-glow), transparent);
      pointer-events: none;
    }
    .header-brand {
      display: flex;
      align-items: baseline;
      gap: 0.6rem;
    }
    .brand-zh {
      font-family: var(--serif-zh);
      font-size: 1.3rem;
      font-weight: 700;
      color: var(--gold);
      letter-spacing: 0.1em;
      text-shadow: 0 0 20px var(--gold-glow);
      transition: color 0.2s;
    }
    .brand-pinyin {
      font-family: var(--mono);
      font-size: 0.62rem;
      color: var(--gold-dim);
      letter-spacing: 0.08em;
      font-style: italic;
    }
    .header-brand:hover .brand-zh { color: var(--text); }
    .header-nav { display: flex; gap: 0.15rem; }
    .nav-item {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 1px;
      padding: 0.4rem 0.9rem;
      border-radius: 3px;
      color: var(--text-dim);
      transition: all 0.2s;
    }
    .nav-item:hover { background: var(--surface2); color: var(--gold); }
    .nav-zh { font-family: var(--serif-jp); font-size: 0.82rem; letter-spacing: 0.05em; line-height: 1.2; }
    .nav-label { font-family: var(--mono); font-size: 0.52rem; letter-spacing: 0.05em; opacity: 0.5; }

    /* ── Body layout ── */
    .body-wrap {
      display: flex;
      align-items: flex-start;
      min-height: calc(100vh - 56px);
    }
    .main-content {
      flex: 1;
      min-width: 0;
    }

    /* ── Sidebar ── */
    .sidebar {
      width: var(--sidebar-w);
      flex-shrink: 0;
      border-left: 1px solid var(--border-dim);
      padding: 28px 18px;
      position: sticky;
      top: 56px;
      height: calc(100vh - 56px);
      overflow-y: auto;
      display: flex;
      flex-direction: column;
      gap: 20px;
    }
    .sidebar-deco-line {
      width: 1px;
      height: 32px;
      background: linear-gradient(to bottom, transparent, var(--gold-dim));
      margin: 0 auto -8px;
    }
    .sidebar-heading {
      font-family: var(--mono);
      font-size: 0.6rem;
      letter-spacing: 0.25em;
      color: var(--gold-dim);
      text-align: center;
      text-transform: uppercase;
    }

    /* Servant cards */
    .servant-card {
      border: 1px solid var(--border-dim);
      border-radius: 4px;
      padding: 12px;
      background: oklch(0.20 0.10 263 / 0.5);
      animation: servant-appear 0.4s ease both;
    }
    .lilian-card { animation-delay: 0.1s; border-top: 2px solid var(--jade-dim); }
    .lilan-card  { animation-delay: 0.3s; border-top: 2px solid var(--gold-dim); }
    @keyframes servant-appear {
      from { opacity: 0; transform: translateY(6px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    .servant-top {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 10px;
    }
    .servant-avatar {
      width: 48px;
      height: 48px;
      border-radius: 50%;
      overflow: hidden;
      flex-shrink: 0;
      border: 1.5px solid var(--border);
    }
    .lilian-avatar { border-color: var(--jade-dim); }
    .lilan-avatar  { border-color: var(--gold-dim); }
    .servant-avatar img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    .servant-name {
      font-family: var(--serif-zh);
      font-size: 0.95rem;
      font-weight: 600;
      letter-spacing: 0.05em;
    }
    .lilian-name { color: var(--jade); }
    .lilan-name  { color: var(--gold); }
    .servant-role {
      font-family: var(--mono);
      font-size: 0.55rem;
      color: var(--text-faint);
      letter-spacing: 0.05em;
      margin-top: 2px;
    }
    .servant-speech {
      font-size: 0.72rem;
      line-height: 1.8;
      color: var(--text-dim);
      font-style: italic;
    }

    /* Ornament */
    .sidebar-ornament {
      display: flex;
      align-items: center;
      gap: 6px;
      padding: 0 8px;
    }
    .orn-line { flex: 1; height: 1px; background: var(--border-dim); }
    .orn-diamond {
      width: 5px;
      height: 5px;
      background: var(--gold-dim);
      transform: rotate(45deg);
      flex-shrink: 0;
    }

    /* Lunar calendar */
    .lunar-box { display: flex; flex-direction: column; gap: 6px; align-items: center; }
    .lunar-compact {
      font-family: var(--serif-zh);
      font-size: 0.68rem;
      color: var(--text-dim);
      text-align: center;
      line-height: 1.9;
    }
    .lunar-loading { color: var(--text-faint); font-family: var(--mono); }
    .lunar-toggle-btn {
      background: none;
      border: 1px solid var(--border-dim);
      border-radius: 3px;
      color: var(--text-faint);
      font-family: var(--mono);
      font-size: 0.56rem;
      letter-spacing: 0.1em;
      padding: 2px 10px;
      cursor: pointer;
      transition: all 0.2s;
    }
    .lunar-toggle-btn:hover { border-color: var(--gold-dim); color: var(--gold-dim); }
    .lunar-grid {
      width: 100%;
      grid-template-columns: repeat(7, 1fr);
      gap: 2px;
    }
    .lunar-day {
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 3px 1px;
      border-radius: 3px;
    }
    .lunar-day.today {
      background: var(--surface2);
      outline: 1px solid var(--gold-dim);
    }
    .day-emoji { font-size: 0.85rem; line-height: 1; }
    .day-num { font-family: var(--mono); font-size: 0.44rem; color: var(--text-faint); margin-top: 1px; }
    .lunar-day.today .day-num { color: var(--gold); }
    .lunar-bday-link {
      font-family: var(--mono);
      font-size: 0.56rem;
      color: var(--text-faint);
      letter-spacing: 0.04em;
      text-align: center;
    }
    .lunar-bday-link:hover { color: var(--gold-dim); }

    /* ── Footer ── */
    .site-footer {
      border-top: 1px solid var(--border-dim);
      padding: 2rem;
      text-align: center;
      margin-top: 0;
    }
    .footer-brand {
      display: flex;
      align-items: baseline;
      justify-content: center;
      gap: 0.6rem;
      margin-bottom: 0.4rem;
    }
    .footer-zh { font-family: var(--serif-zh); font-size: 1rem; color: var(--gold-dim); letter-spacing: 0.1em; }
    .footer-pinyin { font-family: var(--mono); font-size: 0.6rem; color: var(--text-faint); font-style: italic; }
    .footer-motto { font-family: var(--mono); font-size: 0.62rem; color: var(--text-faint); letter-spacing: 0.15em; }

    /* ── Sidebar toggle button（モバイルのみ表示） ── */
    .sidebar-toggle-btn {
      display: none;
      align-items: center;
      justify-content: center;
      width: 36px;
      height: 36px;
      background: none;
      border: 1px solid var(--border-dim);
      border-radius: 4px;
      cursor: pointer;
      transition: all 0.2s;
      margin-left: 0.25rem;
      flex-shrink: 0;
    }
    .sidebar-toggle-btn:hover { border-color: var(--gold-dim); }
    .sidebar-toggle-btn.open { border-color: var(--gold-dim); background: var(--surface2); }
    .sidebar-toggle-zh {
      font-family: var(--serif-zh);
      font-size: 0.85rem;
      color: var(--gold-dim);
      line-height: 1;
    }
    .sidebar-toggle-btn.open .sidebar-toggle-zh { color: var(--gold); }

    /* ── Backdrop ── */
    .sidebar-backdrop {
      display: none;
      position: fixed;
      inset: 0;
      background: oklch(0.10 0.10 263 / 0.7);
      z-index: 199;
      backdrop-filter: blur(2px);
    }
    .sidebar-backdrop.visible { display: block; }

    /* ── Responsive ── */
    @media (max-width: 960px) {
      .sidebar-toggle-btn { display: flex; }

      .sidebar {
        position: fixed;
        top: 0;
        right: 0;
        height: 100dvh;
        width: min(var(--sidebar-w), 85vw);
        border-left: 1px solid var(--border);
        background: oklch(0.20 0.13 263 / 0.98);
        z-index: 200;
        transform: translateX(100%);
        transition: transform 0.28s cubic-bezier(0.4, 0, 0.2, 1);
        overflow-y: auto;
        padding-top: 72px;
      }
      .sidebar.open {
        transform: translateX(0);
      }
    }
    @media (max-width: 600px) {
      .site-header { padding: 0 1rem; }
      .nav-label { display: none; }
      .nav-item { padding: 0.4rem 0.6rem; }
    }
  </style>

  <script>
    // サイドバー開閉
    const toggleBtn  = document.getElementById('sidebar-toggle');
    const sidebar    = document.querySelector('.sidebar') as HTMLElement;
    const backdrop   = document.getElementById('sidebar-backdrop');

    function openSidebar() {
      sidebar?.classList.add('open');
      backdrop?.classList.add('visible');
      toggleBtn?.classList.add('open');
    }
    function closeSidebar() {
      sidebar?.classList.remove('open');
      backdrop?.classList.remove('visible');
      toggleBtn?.classList.remove('open');
    }

    toggleBtn?.addEventListener('click', () => {
      sidebar?.classList.contains('open') ? closeSidebar() : openSidebar();
    });
    backdrop?.addEventListener('click', closeSidebar);
  </script>

  <script>
    import { getLunarInfo, getMoonPhase, getMoonEmoji, getSolarTerm, getLunarMonthDays } from '../scripts/lunar.js';

    const today = new Date();
    const lunarInfo = getLunarInfo(today);
    const phase     = getMoonPhase(today);
    const solarTerm = getSolarTerm(today);

    const compactEl = document.getElementById('lunar-compact');
    if (compactEl && lunarInfo) {
      const emoji = getMoonEmoji(phase);
      const lines  = [`${emoji} ${lunarInfo.stemBranch}年`, `${lunarInfo.monthName}${lunarInfo.dayName}`];
      if (solarTerm) lines.push(solarTerm);
      compactEl.innerHTML = lines.join('<br>');
    }

    const toggleBtn = document.getElementById('lunar-toggle-btn');
    const gridEl    = document.getElementById('lunar-grid');
    let built = false;

    function buildGrid() {
      if (!gridEl) return;
      const days = getLunarMonthDays(today);
      gridEl.innerHTML = days.map(d => {
        const cls = d.isToday ? 'lunar-day today' : 'lunar-day';
        const st  = getSolarTerm(d.date);
        return `<div class="${cls}" title="${d.dayName}${st ? ' · ' + st : ''}">
          <span class="day-emoji">${d.emoji}</span>
          <span class="day-num">${d.dayIdx + 1}</span>
        </div>`;
      }).join('');
    }

    if (toggleBtn && gridEl) {
      toggleBtn.addEventListener('click', () => {
        const open = gridEl.style.display === 'grid';
        if (open) {
          gridEl.style.display = 'none';
          toggleBtn.textContent = '暦 ▾';
        } else {
          if (!built) { buildGrid(); built = true; }
          gridEl.style.display = 'grid';
          toggleBtn.textContent = '暦 ▴';
        }
      });
    }
  </script>

</body>
</html>
