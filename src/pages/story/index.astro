---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { STORIES } from '../../data/stories.js';
---
<BaseLayout title="物語廊" description="同じ場面を4つの難易度で読む。中日対訳リーダー。">
  <div class="story-index">

    <section class="index-hero">
      <p class="index-eyebrow">物語廊</p>
      <h1 class="index-title-zh">故事廊</h1>
      <p class="index-title-jp">物語廊</p>
      <p class="index-desc">同じ場面を、4つの難易度で読む。<br/>成語が生きた言葉になる場所。</p>
    </section>

    <ul class="story-list">
      {STORIES.map((story, i) => (
        <li class="story-card">
          <a href={`/piaodeng/story/${story.slug}/`} class="story-card-link">
            <span class="card-num">0{i + 1}</span>
            <div class="card-body">
              <p class="card-chengyu">
                <span class="card-chengyu-zh">{story.chengyu}</span>
                <span class="card-chengyu-reading">{story.chengyu_reading}</span>
                <span class="card-chengyu-meaning">{story.chengyu_meaning}</span>
              </p>
              <h2 class="card-title-zh">{story.zh_title}</h2>
              <p class="card-title-jp">{story.title}</p>
              <p class="card-desc">{story.desc}</p>
            </div>
            <span class="card-arrow">→</span>
          </a>
        </li>
      ))}
    </ul>

  </div>
</BaseLayout>

<style>
  .story-index {
    max-width: 720px;
    margin: 0 auto;
    padding: 0 1.5rem 5rem;
  }

  .index-hero {
    text-align: center;
    padding: 3.5rem 0 3rem;
    border-bottom: 1px solid var(--border-dim);
    margin-bottom: 2.5rem;
  }
  .index-eyebrow {
    font-family: var(--mono);
    font-size: 0.65rem;
    letter-spacing: 0.35em;
    color: var(--gold-dim);
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }
  .index-title-zh {
    font-family: var(--serif-zh);
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 900;
    color: var(--gold);
    letter-spacing: 0.1em;
    text-shadow: 0 0 30px var(--gold-glow);
    margin-bottom: 0.4rem;
  }
  .index-title-jp {
    font-family: var(--serif-jp);
    font-size: 1rem;
    color: var(--text-dim);
    margin-bottom: 1rem;
    letter-spacing: 0.08em;
  }
  .index-desc {
    font-family: var(--serif-jp);
    font-size: 0.85rem;
    color: var(--text-faint);
    line-height: 2;
    letter-spacing: 0.05em;
  }

  .story-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  .story-card {
    border: 1px solid var(--border-dim);
    border-radius: 4px;
    margin-bottom: 0.75rem;
    transition: border-color 0.2s;
  }
  .story-card:hover {
    border-color: var(--gold-dim);
  }
  .story-card-link {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 1.5rem;
    text-decoration: none;
    color: inherit;
  }

  .card-num {
    font-family: var(--mono);
    font-size: 1.4rem;
    color: var(--gold-dim);
    letter-spacing: 0.05em;
    flex-shrink: 0;
    width: 2.5rem;
    text-align: center;
  }

  .card-body {
    flex: 1;
  }

  .card-chengyu {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    margin-bottom: 0.4rem;
    flex-wrap: wrap;
  }
  .card-chengyu-zh {
    font-family: var(--serif-zh);
    font-size: 1rem;
    color: var(--gold);
    letter-spacing: 0.05em;
  }
  .card-chengyu-reading {
    font-family: var(--mono);
    font-size: 0.65rem;
    color: var(--jade-dim);
    letter-spacing: 0.08em;
  }
  .card-chengyu-meaning {
    font-family: var(--serif-jp);
    font-size: 0.7rem;
    color: var(--text-faint);
    letter-spacing: 0.03em;
  }

  .card-title-zh {
    font-family: var(--serif-zh);
    font-size: 1.25rem;
    color: var(--text);
    letter-spacing: 0.05em;
    margin-bottom: 0.15rem;
  }
  .card-title-jp {
    font-family: var(--serif-jp);
    font-size: 0.8rem;
    color: var(--text-dim);
    margin-bottom: 0.5rem;
    letter-spacing: 0.05em;
  }
  .card-desc {
    font-family: var(--serif-jp);
    font-size: 0.75rem;
    color: var(--text-faint);
    line-height: 1.8;
    letter-spacing: 0.03em;
  }

  .card-arrow {
    font-family: var(--mono);
    font-size: 1rem;
    color: var(--gold-dim);
    flex-shrink: 0;
    transition: transform 0.2s, color 0.2s;
  }
  .story-card:hover .card-arrow {
    transform: translateX(4px);
    color: var(--gold);
  }

  @media (max-width: 600px) {
    .story-card-link { padding: 1.2rem 1rem; gap: 1rem; }
    .card-num { font-size: 1.1rem; width: 2rem; }
  }
</style>
